#!/bin/bash
# Pre-commit hook to prevent Vercel artifacts

set -e

echo "🔍 Checking for Vercel artifacts..."

# Check for forbidden files/directories
FORBIDDEN_PATTERNS=(
    ".vercel/"
    "vercel.json" 
    "api/"
)

FORBIDDEN_FOUND=false

for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    if git diff --cached --name-only | grep -E "$pattern" > /dev/null 2>&1; then
        echo "❌ BLOCKED: Found Vercel artifact matching '$pattern'"
        FORBIDDEN_FOUND=true
    fi
done

# Check for Vercel environment variables and domains in files (excluding security/policy files)
STAGED_FILES=$(git diff --cached --name-only)
for file in $STAGED_FILES; do
    # Skip policy/security files that are allowed to contain references
    if [[ "$file" == "SECURITY.md" || "$file" == .githooks/* || "$file" == .github/* || "$file" == scripts/verify_no_vercel.sh ]]; then
        continue
    fi
    
    # Check for VERCEL_ environment variables
    if git diff --cached "$file" | grep -E "^\+" | grep -E "VERCEL_" > /dev/null 2>&1; then
        echo "❌ BLOCKED: Found VERCEL_* environment variables in $file"
        FORBIDDEN_FOUND=true
    fi
    
    # Check for vercel.app domains  
    if git diff --cached "$file" | grep -E "^\+" | grep -E "\.vercel\.app" > /dev/null 2>&1; then
        echo "❌ BLOCKED: Found vercel.app domain references in $file"
        FORBIDDEN_FOUND=true
    fi
done

if [ "$FORBIDDEN_FOUND" = true ]; then
    echo ""
    echo "🚫 COMMIT BLOCKED: This repository is Cloudflare Pages ONLY"
    echo "   Remove Vercel artifacts and try again."
    echo "   See SECURITY.md for deployment policy."
    exit 1
fi

echo "✅ No Vercel artifacts detected - proceeding with commit"